{{- $pages := slice . -}}
{{- with .Site.GetPage "/about" -}}{{ $pages = $pages | append . }}{{- end -}}
{{- with .Site.GetPage "/posts" -}}{{ $pages = $pages | append . }}{{- end -}}
{{- range where .Site.RegularPages "Section" "posts" -}}
  {{- $pages = $pages | append . -}}
{{- end -}}
[{{ range $i, $p := $pages }}{{ if $i }},{{ end }}{"title":{{ $p.Title | jsonify }},"url":{{ $p.RelPermalink | jsonify }},"description":{{ ($p.Params.description | default "") | jsonify }},"content":{{ ($p.Plain | truncate 400) | jsonify }}}{{ end }}]
